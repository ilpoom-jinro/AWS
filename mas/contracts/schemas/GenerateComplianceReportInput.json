        },
        "workflow_id": {
          "title": "Workflow Id",
          "type": "string"
        },
        "success": {
          "title": "Success",
          "type": "boolean"
        },
        "executed_at": {
          "format": "date-time",
          "title": "Executed At",
          "type": "string"
        },
        "action_taken": {
          "title": "Action Taken",
          "type": "string"
        },
        "output": {
          "default": "",
