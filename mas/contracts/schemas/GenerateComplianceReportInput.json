      "title": "ExecutionResult",
      "type": "object"
    },
    "RegulationMapping": {
      "properties": {
        "contract_version": {
          "default": "v1",
          "title": "Contract Version",
          "type": "string"
        },
        "workflow_id": {
          "title": "Workflow Id",
          "type": "string"
        },
        "analyzed_at": {
          "format": "date-time",
          "title": "Analyzed At",
          "type": "string"
        },
        "violated_regulations": {
          "items": {
            "type": "string"
          },
          "title": "Violated Regulations",
          "type": "array"
        },
        "violation_description": {
          "title": "Violation Description",
          "type": "string"
        },
        "blast_radius_safe": {
          "default": false,
          "title": "Blast Radius Safe",
          "type": "boolean"
        },
        "blast_radius_detail": {
          "default": "",
          "title": "Blast Radius Detail",
          "type": "string"
        },
        "isolation_policy_yaml": {
          "default": "",
          "title": "Isolation Policy Yaml",
          "type": "string"
        },
        "confidence": {
          "default": 0.0,
          "maximum": 1.0,
          "minimum": 0.0,
          "title": "Confidence",
          "type": "number"
        },
        "severity": {
          "default": "low",
          "enum": [
            "critical",
            "high",
            "medium",
            "low"
          ],
          "title": "Severity",
          "type": "string"
        },
        "evidence": {
          "description": "CloudTrail Event ID, GuardDuty Finding ID, Flow Log 등 근거 증적",
          "title": "Evidence",
          "type": "object"
        }
      },
      "required": [
        "workflow_id",
        "violated_regulations",
        "violation_description"
      ],
      "title": "RegulationMapping",
      "type": "object"
    },
    "SecurityEvent": {
      "properties": {
        "contract_version": {
          "default": "v1",
          "title": "Contract Version",
          "type": "string"
        },
        "workflow_id": {
          "title": "Workflow Id",
          "type": "string"
        },
        "detected_at": {
          "format": "date-time",
          "title": "Detected At",
          "type": "string"
        },
        "cluster_name": {
          "title": "Cluster Name",
          "type": "string"
        },
        "namespace": {
          "title": "Namespace",
          "type": "string"
        },
        "source_pod": {
          "title": "Source Pod",
          "type": "string"
        },
        "source_ip": {
          "format": "ipvanyaddress",
          "title": "Source Ip",
          "type": "string"
        },
        "destination_ip": {
          "format": "ipvanyaddress",
          "title": "Destination Ip",
          "type": "string"
        },
        "destination_port": {
          "maximum": 65535,
          "minimum": 1,
          "title": "Destination Port",
          "type": "integer"
        },
        "protocol": {
          "enum": [
            "tcp",
            "udp",
            "icmp"
          ],
          "title": "Protocol",
          "type": "string"
        },
        "direction": {
          "enum": [
            "inbound",
            "outbound"
          ],
          "title": "Direction",
          "type": "string"
        },
        "threat_type": {
          "enum": [
            "abnormal_outbound",
            "port_scan",
            "data_exfiltration",
            "policy_violation"
          ],
          "title": "Threat Type",
          "type": "string"
        },
        "raw_log": {
          "default": "",
          "title": "Raw Log",
          "type": "string"
        },
        "confidence": {
          "default": 0.0,
          "maximum": 1.0,
          "minimum": 0.0,
          "title": "Confidence",
          "type": "number"
        },
        "severity": {
          "default": "low",
          "enum": [
            "critical",
            "high",
            "medium",
            "low"
          ],
          "title": "Severity",
          "type": "string"
        },
        "event_source": {
          "default": "stub",
          "enum": [
            "vpc_flow_log",
            "cloudtrail",
            "guardduty",
            "tetragon",
            "stub"
          ],
          "title": "Event Source",
          "type": "string"
        }
      },
      "required": [
        "cluster_name",
        "namespace",
        "source_pod",
        "source_ip",
        "destination_ip",
        "destination_port",
        "protocol",
        "direction",
        "threat_type"
      ],
      "title": "SecurityEvent",
      "type": "object"
    }
