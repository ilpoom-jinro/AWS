# 로컬 개발용 — 운영은 ConfigMap/Secret 주입
AWS_REGION=ap-northeast-2
OPS_KUBE_CONTEXT=financial-ops-eks
SERVICE_KUBE_CONTEXT=financial-service-eks
OPS_EKS_CLUSTER_NAME=financial-ops-eks
SERVICE_EKS_CLUSTER_NAME=financial-service-eks
VERIFY_WAIT_SEC=300
RCA_CONFIDENCE_MIN=0.7
TEMPORAL_HOST=temporal-frontend.temporal.svc.cluster.local:7233
TEMPORAL_NAMESPACE=default
TEMPORAL_TASK_QUEUE=aiops-task-queue
# shared.config (감사 로그 RDS)
DATABASE_URL=postgresql+asyncpg://user:pass@localhost:5432/mas_audit
