global:
  domain: argocd.internal.ops.local
  image:
    repository: "{{ argocd_image_repository }}"
    tag: "{{ argocd_image_tag }}"

configs:
  params:
    server.insecure: false
  # Kyverno CRD는 262144 bytes 초과로 ArgoCD annotation 방식 관리 불가.
  # CRD는 buildspec helm template으로 별도 관리하므로 ArgoCD 동기화 대상에서 제외.
  resource.exclusions: |
    - apiGroups:
      - apiextensions.k8s.io
      kinds:
      - CustomResourceDefinition
      clusters:
      - '*'

server:
  service:
    type: ClusterIP

controller:
  replicas: 1

repoServer:
  replicas: 1
  serviceAccount:
    create: true
    name: argocd-repo-server

redis:
  image:
    repository: "{{ argocd_redis_image_repository }}"
    tag: "{{ argocd_redis_image_tag }}"

applicationSet:
  replicas: 1

dex:
  enabled: false

notifications:
  enabled: false
