{% for agent in mas_agents %}
apiVersion: v1
kind: ServiceAccount
metadata:
  name: {{ agent.service_account_name }}
  namespace: {{ mas_namespace }}
  labels:
    app.kubernetes.io/name: {{ agent.name }}
    app.kubernetes.io/component: mas-agent
    mas.financial.io/agent-role: {{ agent.role }}
    app.kubernetes.io/managed-by: ansible
{% if agent.kubernetes_readonly | default(false) %}
---
apiVersion: rbac.authorization.k8s.io/v1
kind: ClusterRole
metadata:
  name: {{ agent.name }}-reader
  labels:
    app.kubernetes.io/name: {{ agent.name }}
    app.kubernetes.io/component: mas-agent
    app.kubernetes.io/managed-by: ansible
rules:
  - apiGroups: [""]
    resources: ["pods", "services", "endpoints", "events", "namespaces", "nodes"]
    verbs: ["get", "list", "watch"]
  - apiGroups: ["apps"]
    resources: ["deployments", "replicasets", "statefulsets", "daemonsets"]
    verbs: ["get", "list", "watch"]
  - apiGroups: ["argoproj.io"]
    resources: ["applications"]
    verbs: ["get", "list", "watch"]
---
apiVersion: rbac.authorization.k8s.io/v1
kind: ClusterRoleBinding
metadata:
  name: {{ agent.name }}-reader
  labels:
    app.kubernetes.io/name: {{ agent.name }}
    app.kubernetes.io/component: mas-agent
    app.kubernetes.io/managed-by: ansible
roleRef:
  apiGroup: rbac.authorization.k8s.io
  kind: ClusterRole
  name: {{ agent.name }}-reader
subjects:
  - kind: ServiceAccount
    name: {{ agent.service_account_name }}
    namespace: {{ mas_namespace }}
{% endif %}
---
apiVersion: apps/v1
kind: Deployment
metadata:
  name: {{ agent.name }}
  namespace: {{ mas_namespace }}
  labels:
    app.kubernetes.io/name: {{ agent.name }}
    app.kubernetes.io/component: mas-agent
    mas.financial.io/agent-role: {{ agent.role }}
    app.kubernetes.io/managed-by: ansible
spec:
  replicas: {{ agent.replicas }}
  selector:
    matchLabels:
      app.kubernetes.io/name: {{ agent.name }}
  template:
    metadata:
      labels:
        app.kubernetes.io/name: {{ agent.name }}
        app.kubernetes.io/component: mas-agent
        mas.financial.io/agent-role: {{ agent.role }}
    spec:
      serviceAccountName: {{ agent.service_account_name }}
      containers:
        - name: {{ agent.name }}
          image: {{ agent.image }}
          imagePullPolicy: IfNotPresent
          ports:
            - name: http
              containerPort: {{ agent.container_port }}
          env:
            - name: MAS_SERVICE_NAME
              value: {{ agent.name | quote }}
            - name: MAS_AGENT_ROLE
              value: {{ agent.role | quote }}
            - name: AWS_REGION
              value: {{ aws_region | quote }}
            - name: BEDROCK_MODEL_ID
              value: {{ agent.bedrock_model_id | quote }}
            - name: BEDROCK_MAX_TOKENS
              value: {{ agent.bedrock_max_tokens | quote }}
            - name: PROMETHEUS_URL
              value: {{ agent.prometheus_url | quote }}
            - name: TEMPORAL_HOST
              value: {{ temporal_frontend_host | quote }}
            - name: TEMPORAL_NAMESPACE
              value: {{ mas_namespace | quote }}
            - name: TEMPORAL_ORCHESTRATOR_TASK_QUEUE
              value: "mas-orchestrator"
            - name: TEMPORAL_OBSERVER_TASK_QUEUE
              value: "mas-observer-agent"
            - name: TEMPORAL_ANALYZER_TASK_QUEUE
              value: "mas-analyzer-agent"
{% if agent.observer_url is defined %}
            - name: MAS_OBSERVER_URL
              value: {{ agent.observer_url | quote }}
{% endif %}
{% if agent.analyzer_url is defined %}
            - name: MAS_ANALYZER_URL
              value: {{ agent.analyzer_url | quote }}
{% endif %}
{% if agent.orchestrator_url is defined %}
            - name: MAS_ORCHESTRATOR_URL
              value: {{ agent.orchestrator_url | quote }}
{% endif %}
          readinessProbe:
            httpGet:
              path: /health
              port: http
            initialDelaySeconds: 5
            periodSeconds: 10
          livenessProbe:
            httpGet:
              path: /health
              port: http
            initialDelaySeconds: 15
            periodSeconds: 20
          resources:
            requests:
              cpu: {{ agent.cpu_request }}
              memory: {{ agent.memory_request }}
            limits:
              cpu: {{ agent.cpu_limit }}
              memory: {{ agent.memory_limit }}
{% if agent.service_enabled | default(true) %}
---
apiVersion: v1
kind: Service
metadata:
  name: {{ agent.service_name }}
  namespace: {{ mas_namespace }}
  labels:
    app.kubernetes.io/name: {{ agent.name }}
    app.kubernetes.io/component: mas-agent
    mas.financial.io/agent-role: {{ agent.role }}
    app.kubernetes.io/managed-by: ansible
spec:
  type: ClusterIP
  selector:
    app.kubernetes.io/name: {{ agent.name }}
  ports:
    - name: http
      port: {{ agent.service_port }}
      targetPort: http
{% endif %}
{% if not loop.last %}
---
{% endif %}
{% endfor %}
{% if teleport_app_service_enabled | default(false) %}
---
apiVersion: v1
kind: ServiceAccount
metadata:
  name: teleport-app-service
  namespace: {{ mas_namespace }}
  labels:
    app.kubernetes.io/name: teleport-app-service
    app.kubernetes.io/component: access-proxy
    app.kubernetes.io/managed-by: ansible
---
apiVersion: apps/v1
kind: Deployment
metadata:
  name: teleport-app-service
  namespace: {{ mas_namespace }}
  labels:
    app.kubernetes.io/name: teleport-app-service
    app.kubernetes.io/component: access-proxy
    app.kubernetes.io/managed-by: ansible
spec:
  replicas: 1
  selector:
    matchLabels:
      app.kubernetes.io/name: teleport-app-service
  template:
    metadata:
      labels:
        app.kubernetes.io/name: teleport-app-service
        app.kubernetes.io/component: access-proxy
    spec:
      serviceAccountName: teleport-app-service
      containers:
        - name: teleport-app-service
          image: {{ teleport_app_image }}
          imagePullPolicy: IfNotPresent
          command:
            - /bin/sh
            - -ec
            - |
              TOKEN="$(cat /var/run/secrets/teleport/token)"
              cat > /tmp/teleport.yaml <<EOF
              version: v3
              teleport:
                nodename: mas-ui-app-service
                data_dir: /var/lib/teleport
                auth_token: ${TOKEN}
                proxy_server: {{ teleport_proxy_server }}
                log:
                  output: stderr
                  severity: INFO
              auth_service:
                enabled: false
              ssh_service:
                enabled: false
              proxy_service:
                enabled: false
              app_service:
                enabled: true
                apps:
                  - name: mas-ui
                    uri: http://mas-ui.{{ mas_namespace }}.svc.cluster.local:8080
                    public_addr: {{ teleport_mas_ui_public_addr }}
              EOF
              teleport start -c /tmp/teleport.yaml
          volumeMounts:
            - name: teleport-join-token
              mountPath: /var/run/secrets/teleport
              readOnly: true
          resources:
            requests:
              cpu: 100m
              memory: 128Mi
            limits:
              cpu: 500m
              memory: 512Mi
      volumes:
        - name: teleport-join-token
          secret:
            secretName: {{ teleport_app_join_token_secret_name }}
{% endif %}
