# ── Terraform ────────────────────────────────────────────────
# Provider cache / plugin directories (all module depths)
**/.terraform/
.terraform.tfstate.lock.info

# State files
*.tfstate
*.tfstate.*
*.tfstate.backup

# Plan output (may contain plaintext secrets)
*.tfplan
*.tfplan.json
plan.log

# Crash logs
crash.log
crash.*.log

# Variable files with real values — commit only *.tfvars.example
*.tfvars
*.tfvars.json
!*.tfvars.example

# Override files (local dev; not for version control)
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# CLI configuration
.terraformrc
terraform.rc

# archive_file이 terraform plan/apply 시마다 생성하는 Lambda 패키징 zip
# (slack-broker.tf) — 소스(handler.py)만 커밋하고 산출물은 커밋하지 않음
lambda/**/build/

# ── Packer ───────────────────────────────────────────────────
packer/manifest.json
packer/manifest.json.lock
packer/*.pkrvars.hcl
!*.pkrvars.hcl.example

# ── Credentials & Keys ───────────────────────────────────────
*.pem
*.key
id_rsa
id_rsa.*
id_ed25519
id_ed25519.*
mfa-auth.sh

# ── Environment files ────────────────────────────────────────
.env
.env.*
!.env.example

# ── Local runtime artifacts ──────────────────────────────────
# SSM/port-forward parameter files (contain instance IDs)
input.json
params.json

# ── Python ───────────────────────────────────────────────────
__pycache__/
*.pyc

# ── Tools ────────────────────────────────────────────────────
.claude/

# ── OS ───────────────────────────────────────────────────────
.DS_Store
Thumbs.db
session-manager-plugin.deb
desktop.ini
